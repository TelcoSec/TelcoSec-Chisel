[Desktop Entry]
Version=1.0
Type=Application
Name=APN Permutator
Comment=Generate APN name permutations for carrier network enumeration
Exec=gnome-terminal --title "APN Permutator" -- bash -c "bash -c 'telcosec-apn-permutator --help; echo; read -rp \"Press Enter to close...\"'"
